# Server Configuration
PORT=5000
NODE_ENV=development

# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
# 
# SUPABASE_URL: Found in Project Settings → API → Project URL
#   Example: https://xxxxxxxxxxxxx.supabase.co
#
# SUPABASE_SERVICE_ROLE_KEY: Found in Project Settings → API → service_role key (secret)
#   ⚠️  KEEP THIS SECRET! Never expose it to the client/frontend
#   This key bypasses Row Level Security (RLS) - use only server-side
#
# SUPABASE_ANON_KEY: Found in Project Settings → API → anon/public key
#   This is safe to use in client-side code (if needed)
# ============================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Secret (for custom authentication)
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars

# Email Configuration (SendGrid or SMTP)
# Option 1: SendGrid (Recommended - Free tier: 100 emails/day)
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key

# Option 2: SMTP (Gmail example)
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password_here

EMAIL_FROM=noreply@peerly.com

# Allowed Email Domains (for verification)
# Comma-separated list of email domains that can register
# Each domain must start with @ (e.g., @gmail.com,@college.edu)
# Default: @gmail.com (if not set)
# See docss/EMAIL_DOMAIN_CONFIG.md for details
ALLOWED_EMAIL_DOMAINS=@gmail.com,@college.edu

# Google OAuth Configuration (REQUIRED)
# Get these from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Create OAuth 2.0 Client ID credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=2097152
